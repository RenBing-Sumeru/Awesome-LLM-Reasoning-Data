# Copy this file to .env locally or configure equivalent deployment secrets.
# Never commit real secrets.

ASK_ATLAS_PORT=8787
ASK_ATLAS_ENV=dev
ASK_ATLAS_BASE_URL=http://localhost:8787
ASK_ATLAS_PAGES_BASE_URL=https://renbing-sumeru.github.io/Awesome-LLM-Reasoning-Data
# Optional comma-separated extra frontend origins allowed to call /api/*.
# The project GitHub Pages origin is allowed from ASK_ATLAS_PAGES_BASE_URL.
ASK_ATLAS_ALLOWED_ORIGINS=
ASK_ATLAS_SESSION_SECRET=replace-with-a-long-random-secret
ASK_ATLAS_TOKEN_ENCRYPTION_SECRET=replace-with-another-long-random-secret

# GitHub OAuth App settings.
# Callback URL for local development:
#   http://localhost:8787/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# OAuth token retention for GitHub reward checks. Set 0 to never persist tokens.
ASK_ATLAS_GITHUB_TOKEN_RETENTION_DAYS=30

# Local storage and distributed rate limiting.
# Public production traffic must override this with ASK_ATLAS_STORE_BACKEND=postgres
# plus Redis/Upstash. The local JSON setting is intentionally rejected by
# production config unless a private deployment explicitly opts in.
ASK_ATLAS_STORE_BACKEND=json
DATABASE_URL=
ASK_ATLAS_DATABASE_SSL=auto
ASK_ATLAS_ALLOW_JSON_STORE=0
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Production requires Redis/Upstash for multi-instance atomic rate limiting.
# Set this only for a private single-instance deployment where local fallback is acceptable.
ASK_ATLAS_ALLOW_LOCAL_RATE_LIMIT=0
ASK_ATLAS_TRUST_PROXY=0

# 360 OpenAI-compatible API settings.
QIHOO_API_BASE=https://api.360.cn/v1
QIHOO_API_KEY=
ASK_ATLAS_DEFAULT_MODEL=deepseek/deepseek-v4-pro
ASK_ATLAS_ALLOWED_MODELS=deepseek/deepseek-v4-pro,z-ai/glm-5.2

# Access control.
ASK_ATLAS_ADMIN_LOGINS=RenBing-Sumeru
ASK_ATLAS_ADMIN_GITHUB_IDS=
# Login-based allowlists are for local/private experiments only. Production
# rejects this setting because GitHub logins are mutable; use numeric IDs.
ASK_ATLAS_ALLOWLIST_LOGINS=
ASK_ATLAS_ALLOWLIST_GITHUB_IDS=

# Quota and cost caps.
ASK_ATLAS_BASE_DAILY_REQUESTS=2
ASK_ATLAS_STAR_BONUS_CREDITS=10
ASK_ATLAS_FORK_BONUS_CREDITS=20
ASK_ATLAS_ADMIN_DAILY_REQUESTS=1000
ASK_ATLAS_MAX_INPUT_CHARS=4000
ASK_ATLAS_MAX_OUTPUT_TOKENS=1200
ASK_ATLAS_MIN_RETRIEVAL_CONFIDENCE=0.18
ASK_ATLAS_USER_DAILY_TOKEN_CAP=150000
ASK_ATLAS_USER_DAILY_COST_CAP_USD=0.50
ASK_ATLAS_MAX_SINGLE_REQUEST_COST_USD=0.08
ASK_ATLAS_GLOBAL_DAILY_COST_CAP_USD=20
ASK_ATLAS_QUOTA_RESERVATION_TTL_MS=300000
ASK_ATLAS_PER_USER_MINUTE_LIMIT=2
ASK_ATLAS_PER_IP_HOUR_LIMIT=20
ASK_ATLAS_ATTEMPT_PER_USER_MINUTE_LIMIT=6
ASK_ATLAS_ATTEMPT_PER_IP_HOUR_LIMIT=60
ASK_ATLAS_REWARD_REFRESH_HOURLY_LIMIT=6
ASK_ATLAS_GLOBAL_MINUTE_LIMIT=60
ASK_ATLAS_GITHUB_FORK_SCAN_PAGES=10

# Required estimated pricing for production cost caps.
# Values are USD per 1M tokens. Do not copy the example numbers into
# production; replace them with the current provider prices before launch.
ASK_ATLAS_MODEL_RATES_JSON={"deepseek/deepseek-v4-pro":{"input_per_million":"REPLACE_WITH_CURRENT_PRICE","output_per_million":"REPLACE_WITH_CURRENT_PRICE"},"z-ai/glm-5.2":{"input_per_million":"REPLACE_WITH_CURRENT_PRICE","output_per_million":"REPLACE_WITH_CURRENT_PRICE"}}
ASK_ATLAS_REQUIRE_MODEL_RATES=1

# Optional backend-only paper text source. Keep private if needed. If set,
# the file must live under ASK_ATLAS_SAFE_RAG_ROOT, must be .txt/.md, and must
# not be a config, secret, log, database, or structured data file.
ASK_ATLAS_SAFE_RAG_ROOT=private/primer
ASK_ATLAS_MAX_PRIMER_TEXT_BYTES=5242880
ASK_ATLAS_PRIMER_TEXT_PATH=

# Local development only. Do not enable in production.
ASK_ATLAS_DEV_AUTH=0
ASK_ATLAS_MOCK_PROVIDER=0
